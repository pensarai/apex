{
  "name": "@pensar/apex",
  "version": "1.0.0",
  "description": "AI-powered penetration testing CLI tool with terminal UI",
  "module": "src/tui/index.tsx",
  "main": "build/tui/index.js",
  "type": "module",
  "bin": {
    "pensar": "./bin/pensar.js"
  },
  "files": [
    "build",
    "bin",
    "container",
    "pensar.svg"
  ],
  "scripts": {
    "build": "bun build src/tui/index.tsx --outdir build --target node --format esm",
    "dev": "bun run scripts/watch.ts",
    "dev:debug": "SHOW_CONSOLE=true bun run scripts/watch.ts",
    "start": "bun run src/tui/index.tsx",
    "pensar": "node bin/pensar.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "penetration-testing",
    "security",
    "pentesting",
    "ai",
    "cli",
    "terminal",
    "tui"
  ],
  "author": "Pensar",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^3.0.34",
    "@ai-sdk/anthropic": "^2.0.26",
    "@ai-sdk/openai": "^2.0.48",
    "@layered/dns-records": "^2.3.0",
    "@openrouter/ai-sdk-provider": "^1.2.0",
    "@opentui/core": "link:@opentui/core",
    "@opentui/react": "link:@opentui/react",
    "ai": "^5.0.68",
    "marked": "^16.4.0",
    "nanoid": "^5.1.6",
    "react": "^19.2.0",
    "sharp": "^0.34.4",
    "zod": "^4.1.12"
  }
}
